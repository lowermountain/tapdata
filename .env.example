# ── API Security ──────────────────────────────────────────────────────────────
# Shared secret used as a Bearer token to authenticate inbound requests.
# Generate a strong random value: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=change_me_to_a_strong_random_token

# ── FileMaker OData ───────────────────────────────────────────────────────────
# Full URL of your FileMaker Server (no trailing slash)
FM_SERVER=https://your-fm-server.example.com

# Name of the hosted FileMaker database (as shown in Admin Console)
FM_DATABASE=YourDatabase

# OData entity name — this is the FM table name as exposed via OData
FM_TABLE=YourTable

# FM field where the full JSON payload will be stored (Text field, large enough)
FM_JSON_FIELD=JSONData

# FileMaker credentials (account must have fmrest + OData extended privileges)
FM_USERNAME=api_user
FM_PASSWORD=change_me

# ── Optional ──────────────────────────────────────────────────────────────────
# If set, stamps this FM field with the value of the X-Source request header
# Leave blank to disable
FM_SOURCE_FIELD=
