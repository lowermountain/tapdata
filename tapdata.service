[Unit]
Description=tapdata ingestion API
After=network.target

[Service]
Type=simple
User=tapdata
WorkingDirectory=/opt/tapdata
EnvironmentFile=/opt/tapdata/.env
ExecStart=/opt/tapdata/venv/bin/uvicorn app:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=5
# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/opt/tapdata

[Install]
WantedBy=multi-user.target
